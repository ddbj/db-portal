    "date-fns": "^4.1.0",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "isbot": "^5.1.36",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.4",
    "react-router": "7.14.0",
    "tailwind-merge": "^3.5.0"
