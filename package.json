    "@vitest/coverage-v8": "^3",
    "@vitest/eslint-plugin": "^1",
    "eslint": "^9",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-simple-import-sort": "^12",
    "eslint-plugin-tailwindcss": "^3.18",
    "fast-check": "^4.7.0",
    "globals": "^16",
    "jsdom": "^26",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8",
