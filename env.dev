# DB Portal Dev Environment
# Usage: cp env.dev .env && docker compose up -d --build

# --- Compose ---
DB_PORTAL_ENV=dev
TZ=Asia/Tokyo
APP_COMMAND=sleep infinity
APP_PORT=3000
APP_INTERNAL_PORT=3000

# --- Keycloak (DDBJ Account staging) ---
KEYCLOAK_REALM_URL=https://idp-staging.ddbj.nig.ac.jp/realms/master
KEYCLOAK_CLIENT_ID=db-portal-dev

# --- Search API ---
DB_PORTAL_SEARCH_API_URL=https://ddbj-staging.nig.ac.jp/search/api

# --- Portal origin (canonical URL 等で参照、docs/deployment.md 参照) ---
VITE_PORTAL_ORIGIN=http://localhost:3000
