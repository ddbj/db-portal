# DB Portal Production Environment

# --- Compose ---
COMPOSE_FILE=compose.yml:compose.podman.yml
DB_PORTAL_ENV=production
TZ=Asia/Tokyo
APP_COMMAND=npm run start
APP_PORT=3100
APP_INTERNAL_PORT=3100

# --- Keycloak (DDBJ Account production) ---
KEYCLOAK_REALM_URL=https://idp.ddbj.nig.ac.jp/realms/master
KEYCLOAK_CLIENT_ID=db-portal
